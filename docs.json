{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Canary Edge",
  "colors": {
    "primary": "#F5C542",
    "light": "#FFE588",
    "dark": "#0F2035",
    "background": {
      "dark": "#0A1628"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "concepts"
            ]
          },
          {
            "group": "Migration Guides",
            "pages": [
              "guides/azure-migration",
              "guides/aws-migration"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "guides/fine-tuning",
              "guides/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Azure-Compatible",
            "pages": [
              "api-reference/endpoint/detect",
              "api-reference/endpoint/detect-last",
              "api-reference/endpoint/detect-changepoint"
            ]
          },
          {
            "group": "Native API",
            "pages": [
              "api-reference/endpoint/native-detect",
              "api-reference/endpoint/baseline",
              "api-reference/endpoint/status",
              "api-reference/endpoint/machines",
              "api-reference/endpoint/usage"
            ]
          },
          {
            "group": "System",
            "pages": [
              "api-reference/endpoint/health"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Status",
          "href": "https://status.canaryedge.com",
          "icon": "signal"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/CanaryEdge",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@canaryedge.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://canaryedge.com/dashboard"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/CanaryEdge",
      "linkedin": "https://linkedin.com/company/canaryedge"
    }
  },
  "api": {
    "baseUrl": "https://api.canaryedge.com"
  },
  "feedback": {
    "thumbsRating": true
  }
}
